{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>elhub/devxp-renovate"],
  "customManagers": [
    {
      "description": "Megalinter image version in config.go",
      "customType": "regex",
      "managerFilePatterns": [
        "/^pkg/config/config\\.go$/"
      ],
      "matchStrings": [
        "MegalinterImageVersion\\s*:\\s*\"docker.jfrog.elhub.cloud/oxsecurity/megalinter-cupcake:(?<currentValue>.*?)\""
      ],
      "packageNameTemplate": "oxsecurity/megalinter",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    }
  ]
}
